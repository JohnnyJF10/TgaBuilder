<UserControl x:Class="TgaBuilderAvaloniaUi.View.TransitionModeUserControl"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converter="clr-namespace:TgaBuilderAvaloniaUi.Converters"
             xmlns:ap="clr-namespace:TgaBuilderAvaloniaUi.AttachedProperties"
             xmlns:transitions="clr-namespace:TgaBuilderLib.Transitions;assembly=TgaBuilderLib"
             mc:Ignorable="d"
             x:CompileBindings="False">
    <UserControl.Resources>
        <converter:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="RadioButton.toggle-look">
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="{DynamicResource ButtonBorderThemeThickness}" />
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.toggle-look:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrushPointerOver}" />
        </Style>
        <Style Selector="RadioButton.toggle-look:pressed /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundPressed}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrushPressed}" />
        </Style>
        <Style Selector="RadioButton.toggle-look:checked /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource ToggleButtonBackgroundChecked}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToggleButtonBorderBrushChecked}" />
        </Style>
        <Style Selector="RadioButton.toggle-look:checked:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource ToggleButtonBackgroundCheckedPointerOver}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToggleButtonBorderBrushCheckedPointerOver}" />
        </Style>
        <Style Selector="RadioButton.toggle-look:checked:pressed /template/ Border#PART_Border">
            <Setter Property="Background" Value="{DynamicResource ToggleButtonBackgroundCheckedPressed}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ToggleButtonBorderBrushCheckedPressed}" />
        </Style>
    </UserControl.Styles>
    <StackPanel Orientation="Horizontal">
        <!-- Top edge -->
        <RadioButton
            Classes="toggle-look"
            GroupName="TransitionMode"
            ap:MouseOverInfoAP.InfoText="Transition from top edge"
            IsChecked="{Binding TransitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static transitions:TransitionMode.Top}}"
            Margin="0,0,5,0">
            <Panel Width="20" Height="20">
                <PathIcon Data="M0,0 L20,0 L20,20 L0,20 Z"
                          Foreground="{DynamicResource SystemAccentColorDark1}"
                          Width="20" Height="20"/>
                <Line StartPoint="0,0" EndPoint="20,0"
                      Stroke="{DynamicResource SystemAccentColorLight3}"
                      StrokeThickness="2"/>
            </Panel>
        </RadioButton>

        <!-- Right edge -->
        <RadioButton
            Classes="toggle-look"
            GroupName="TransitionMode"
            ap:MouseOverInfoAP.InfoText="Transition from right edge"
            IsChecked="{Binding TransitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static transitions:TransitionMode.Right}}"
            Margin="0,0,5,0">
            <Panel Width="20" Height="20">
                <PathIcon Data="M0,0 L20,0 L20,20 L0,20 Z"
                          Foreground="{DynamicResource SystemAccentColorDark1}"
                          Width="20" Height="20"/>
                <Line StartPoint="20,0" EndPoint="20,20"
                      Stroke="{DynamicResource SystemAccentColorLight3}"
                      StrokeThickness="2"/>
            </Panel>
        </RadioButton>

        <!-- Bottom edge -->
        <RadioButton
            Classes="toggle-look"
            GroupName="TransitionMode"
            ap:MouseOverInfoAP.InfoText="Transition from bottom edge"
            IsChecked="{Binding TransitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static transitions:TransitionMode.Bottom}}"
            Margin="0,0,5,0">
            <Panel Width="20" Height="20">
                <PathIcon Data="M0,0 L20,0 L20,20 L0,20 Z"
                          Foreground="{DynamicResource SystemAccentColorDark1}"
                          Width="20" Height="20"/>
                <Line StartPoint="0,20" EndPoint="20,20"
                      Stroke="{DynamicResource SystemAccentColorLight3}"
                      StrokeThickness="2"/>
            </Panel>
        </RadioButton>

        <!-- Left edge -->
        <RadioButton
            Classes="toggle-look"
            GroupName="TransitionMode"
            ap:MouseOverInfoAP.InfoText="Transition from left edge"
            IsChecked="{Binding TransitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static transitions:TransitionMode.Left}}"
            Margin="0,0,5,0">
            <Panel Width="20" Height="20">
                <PathIcon Data="M0,0 L20,0 L20,20 L0,20 Z"
                          Foreground="{DynamicResource SystemAccentColorDark1}"
                          Width="20" Height="20"/>
                <Line StartPoint="0,0" EndPoint="0,20"
                      Stroke="{DynamicResource SystemAccentColorLight3}"
                      StrokeThickness="2"/>
            </Panel>
        </RadioButton>

        <!-- Diagonal top-left -->
        <RadioButton
            Classes="toggle-look"
            GroupName="TransitionMode"
            ap:MouseOverInfoAP.InfoText="Transition from diagonal (top-left)"
            IsChecked="{Binding TransitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static transitions:TransitionMode.DiagonalTopLeft}}"
            Margin="0,0,5,0">
            <Panel Width="20" Height="20">
                <PathIcon Data="M0,0 L20,0 L20,20 L0,20 Z"
                          Foreground="{DynamicResource SystemAccentColorDark1}"
                          Width="20" Height="20"/>
                <Line StartPoint="0,20" EndPoint="20,0"
                      Stroke="{DynamicResource SystemAccentColorLight3}"
                      StrokeThickness="2"/>
            </Panel>
        </RadioButton>

        <!-- Diagonal top-right -->
        <RadioButton
            Classes="toggle-look"
            GroupName="TransitionMode"
            ap:MouseOverInfoAP.InfoText="Transition from diagonal (top-right)"
            IsChecked="{Binding TransitionMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter={x:Static transitions:TransitionMode.DiagonalTopRight}}"
            Margin="0,0,5,0">
            <Panel Width="20" Height="20">
                <PathIcon Data="M0,0 L20,0 L20,20 L0,20 Z"
                          Foreground="{DynamicResource SystemAccentColorDark1}"
                          Width="20" Height="20"/>
                <Line StartPoint="0,0" EndPoint="20,20"
                      Stroke="{DynamicResource SystemAccentColorLight3}"
                      StrokeThickness="2"/>
            </Panel>
        </RadioButton>
    </StackPanel>
</UserControl>
