<elements:AsyncWindow
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:elements="clr-namespace:TgaBuilderAvaloniaUi.Elements"
    xmlns:local="clr-namespace:TgaBuilderAvaloniaUi.View"
    xmlns:converters="clr-namespace:TgaBuilderAvaloniaUi.Converters"
    xmlns:viewmodel="clr-namespace:TgaBuilderLib.ViewModel;assembly=TgaBuilderLib"
    xmlns:ap="clr-namespace:TgaBuilderAvaloniaUi.AttachedProperties"
    x:Class="TgaBuilderAvaloniaUi.View.BrickTransitionWindow"
    x:DataType="viewmodel:BrickTransitionViewModel"
    mc:Ignorable="d"
    WindowStartupLocation="CenterScreen"
    UseLayoutRounding="True"
    Background="{DynamicResource WindowBackgroundGradient}"
    Foreground="{DynamicResource SystemBaseHighColor}"
    Title="Brick Transition Helper"
    Width="660"
    Height="300"
    MinWidth="660"
    MinHeight="300"
    Icon="avares://TgaBuilderAvaloniaUi/Resources/TgaBuilder_icon.ico">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/CheckerBrush.axaml" />
                <ResourceInclude Source="/Styles/TabControlStyles.axaml" />
                <ResourceInclude Source="/Styles/IconToggleButtonStyle.axaml"/>
                <ResourceInclude Source="/Styles/IconButtonStyle.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:WriteableBitmapConverter x:Key="WriteableBitmapConverter" />
            <converters:ColorStructToMediaColor   x:Key="ColorStructToMediaColor"/>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer Grid: 2 Rows -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Settings / Options -->
        <Grid Grid.Row="0" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Col 0, Row 0: Transition Mode (always visible) -->
            <local:TransitionModeUserControl
                Grid.Column="0" Grid.Row="0"
                Margin="5,5,10,5" />

            <!-- Col 0, Row 1: Always-visible sliders -->
            <StackPanel
                Grid.Column="0" Grid.Row="1"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="5,0,10,5">
                <DockPanel Width="130" VerticalAlignment="Center" Margin="0,0,8,0"
                           ap:MouseOverInfoAP.InfoText="Pivot: sets the position of the brick transition border (0 = left, 1 = right)">
                    <Grid
                        VerticalAlignment="Top"
                        Margin="-5,11,8,0"
                        DockPanel.Dock="Left">
                        <Path VerticalAlignment="Bottom"
                          Stroke="{DynamicResource IconFillBrush}"
                          StrokeThickness="1"
                          Fill="Transparent" Width="10" Height="10" 
                          Data="{StaticResource pivot_low}"/>
                        <Path VerticalAlignment="Bottom"
                          Stroke="{DynamicResource IconFillBrush}"
                          StrokeDashArray="2,2"
                          StrokeThickness="1"
                          Fill="Transparent" Width="10" Height="10" 
                          Data="{StaticResource pivot_high}"/>
                    </Grid>
                    <Grid
                        VerticalAlignment="Top"
                        Margin="-5,11,8,0"
                        DockPanel.Dock="Right">
                        <Path VerticalAlignment="Bottom"
                              StrokeThickness="1"
                          Stroke="{DynamicResource IconFillBrush}"
                          Fill="Transparent" Width="10" Height="10" 
                          Data="{StaticResource pivot_high}"/>
                        <Path VerticalAlignment="Bottom" 
                              StrokeThickness="1"
                          Stroke="{DynamicResource IconFillBrush}"
                          StrokeDashArray="2,2"
                          Fill="Transparent" Width="10" Height="10" 
                          Data="{StaticResource pivot_low}"/>
                    </Grid>
                    <Slider
                        Margin="5,0"
                        VerticalAlignment="Center"
                        ToolTip.Tip="{Binding PivotValue}"
                        Maximum="1" Minimum="0" SmallChange="0.01"
                        Value="{Binding PivotValue}" />
                </DockPanel>
                <elements:IconToggleButton
                    Classes="outlined"
                    Margin="5"
                    VerticalAlignment="Center"
                    ap:MouseOverInfoAP.InfoText="Reverse the pivot direction"
                    Icon="{StaticResource flip_horizontal}"
                    IsChecked="{Binding ReversePivot}" />
            </StackPanel>

            <!-- Col 1, Row 0-1: Tab View -->
            <TabControl
                Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                Margin="0,5,5,5"
                BorderBrush="Transparent"
                TabStripPlacement="Top">

                <!-- Tab: Analysis -->
                <TabItem Height="25" Header="Analysis">
                    <StackPanel Orientation="Horizontal" Margin="5,6,0,0" VerticalAlignment="Center">
                        <DockPanel Width="130" VerticalAlignment="Center" Margin="0,0,15,0"
                                   ap:MouseOverInfoAP.InfoText="Marker Radius: size of the seed markers for segmentation (1 = small, 20 = large)">
                            <Path VerticalAlignment="Center"
                                  Fill="{DynamicResource IconFillBrush}" Width="14" Height="14" Stretch="Uniform"
                                  Data="{StaticResource circle_small}" />
                            <Path DockPanel.Dock="Right" VerticalAlignment="Center"
                                  Fill="{DynamicResource IconFillBrush}" Width="14" Height="14" Stretch="Uniform"
                                  Data="{StaticResource circle}" />
                            <Slider
                                Margin="5,0"
                                VerticalAlignment="Center"
                                ToolTip.Tip="{Binding MarkerRadius}"
                                IsSnapToTickEnabled="True"
                                TickFrequency="1"
                                Maximum="20" Minimum="1" SmallChange="1"
                                Value="{Binding MarkerRadius}" />
                        </DockPanel>
                        <DockPanel
                            ap:MouseOverInfoAP.InfoText="Filter: pre-processing filter applied to the result image">
						    	  <Path VerticalAlignment="Center" Margin="5,0,0,0"
                                  Fill="{DynamicResource IconFillBrush}" Width="14" Height="14" Stretch="Uniform"
                                  Data="{StaticResource filter}" />
                            <ComboBox
                                VerticalAlignment="Center"
                                MinWidth="90"
                                Margin="0,0,15,0"
                                BorderThickness="0"
                                Background="Transparent"
                                SelectedIndex="{Binding SelectedFilterIndex}">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Box Blur"/>
                                <ComboBoxItem Content="Median"/>
                                <ComboBoxItem Content="Bilateral"/>
                            </ComboBox>
                        </DockPanel>
                        <DockPanel
                            ap:MouseOverInfoAP.InfoText="Segmentation method: algorithm used to identify brick regions"
                            >
                            <Path VerticalAlignment="Center" Margin="5,0,0,0"
                                  Fill="{DynamicResource IconFillBrush}" 
                                  Width="18" 
                                  Height="18" 
                                  Stretch="Uniform"
                                  Data="{StaticResource shapes}" />
                            <ComboBox
                                VerticalAlignment="Center"
                                MinWidth="110"
                                BorderThickness="0"
                                Background="Transparent"
                                SelectedIndex="{Binding SelectedSegmentationMethodIndex}">
                                <ComboBoxItem Content="Watershed"/>
                                <ComboBoxItem Content="XY Projection"/> 
                                </ComboBox>
                            </DockPanel>
                    </StackPanel>
                </TabItem>

                <!-- Tab: Options -->
                <TabItem Height="25" Header="Options">
                    <StackPanel Orientation="Horizontal" Margin="5,6,0,0" VerticalAlignment="Center">
                        <elements:IconToggleButton
                            Classes="outlined"
                            VerticalAlignment="Center"
                            ap:MouseOverInfoAP.InfoText="Slice Corners: enable/disable slicing of corner tiles"
                            Icon="{StaticResource cut}"
                            IsChecked="{Binding SliceCornerTiles}" />
                        <elements:IconButton
                            Classes="outlined"
                            Icon="{StaticResource color_line}"
                            Margin="5,0,5,0"
                            ap:MouseOverInfoAP.InfoText="Pick the color which shall be replaced with magenta as transparent color"
                            Command="{Binding PickEdgeColorCommand}"
                            DockPanel.Dock="Left" />

                        <ColorPicker 
                            x:Name="SourceColorPicker"
                            ap:MouseOverInfoAP.InfoText="Pick the color which shall be replaced with magenta as transparent color"
                            Color="{Binding EdgeColor, Converter={StaticResource ColorStructToMediaColor}, Mode=TwoWay}"                            
                        />
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Row 1: Image Area -->
        <Grid Grid.Row="1" x:Name="ImageAreaGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Image 1 (Bricks) -->
            <Border
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent">
                <Grid>
                    <Viewbox Stretch="Uniform" Margin="10"
                             RenderOptions.BitmapInterpolationMode="None">
                        <Grid Width="{Binding Image1.PixelWidth, FallbackValue=128}"
                              Height="{Binding Image1.PixelHeight, FallbackValue=128}">
                            <elements:CheckerRectangle TileDensity="1" />
                            <Image
                                x:Name="Image1"
                                RenderOptions.BitmapInterpolationMode="None"
                                Source="{Binding Image1, Converter={StaticResource WriteableBitmapConverter}}"
                                Stretch="Fill"
                                PointerMoved="Image1_PointerMoved"
                                PointerEntered="Image1_PointerEntered"
                                PointerExited="Image1_PointerExited"
                                PointerPressed="Image1_PointerPressed"
                                />
                        </Grid>
                    </Viewbox>
                    <TextBlock
                        Text="Bricks&#x0a;Texture"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        IsVisible="{Binding InitTextVisible}"
                        FontSize="20"
                        IsHitTestVisible="False" />
                </Grid>
            </Border>

            <!-- + symbol and swap -->
            <StackPanel
                VerticalAlignment="Center"
                Grid.Column="1"
                Margin="0,45,0,0">
                <PathIcon Data="{StaticResource add}"
                          Width="16" Height="16" />
                <elements:IconButton
                    Classes="outlined"
                    Margin="0,9,0,0"
                    Padding="4,0,0,0"
                    Command="{Binding SwapImagesCommand}"
                    ap:MouseOverInfoAP.InfoText="Swap Bricks Texture and Background Texture"
                    ToolTip.Tip="Swap images"
                    Icon="{StaticResource arrow_swap}"/>
            </StackPanel>

            <!-- Image 2 (Background) -->
            <Border
                Grid.Column="2"
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent">
                <Grid>
                    <Viewbox Stretch="Uniform"
                             RenderOptions.BitmapInterpolationMode="None">
                        <Grid Width="{Binding Image2.PixelWidth, FallbackValue=128}"
                              Height="{Binding Image2.PixelHeight, FallbackValue=128}">
                            <elements:CheckerRectangle TileDensity="1" />
                            <Image
                                x:Name="Image2"
                                RenderOptions.BitmapInterpolationMode="None"
                                Source="{Binding Image2, Converter={StaticResource WriteableBitmapConverter}}"
                                Stretch="Fill"
                                PointerMoved="Image2_PointerMoved"
                                PointerEntered="Image2_PointerEntered"
                                PointerExited="Image2_PointerExited"
                                PointerPressed="Image2_PointerPressed"
                                />
                        </Grid>
                    </Viewbox>
                    <TextBlock
                        Text="Background&#x0a;Texture"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        IsVisible="{Binding InitTextVisible}"
                        FontSize="16"
                        IsHitTestVisible="False" />
                </Grid>
            </Border>

            <!-- Mix button (arrow) -->
            <elements:IconButton
                Classes="accent"
                Foreground="White"
                Grid.Column="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0,0,0,-5"
                ap:MouseOverInfoAP.InfoText="Generate the brick transition result image"
                Icon="{StaticResource arrow_forward}"
                Command="{Binding MixCommand}" />

            <!-- Result Image -->
            <Border
                Grid.Column="4"
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="Transparent">
                <Image
                    x:Name="ResultImage"
                    Margin="0,4,0,0"
                    RenderOptions.BitmapInterpolationMode="None"
                    Source="{Binding ResultImage, Converter={StaticResource WriteableBitmapConverter}}"
                    Stretch="Uniform"/>
            </Border>

            <!-- Toggle button for Label Map -->
            <ToggleButton
                x:Name="LabelMapToggle"
                Grid.Column="5"
                VerticalAlignment="Center"
                ap:MouseOverInfoAP.InfoText="Show/hide the segmentation label map"
                IsChecked="{Binding IsLabelMapExpanded}"
                Width="20"
                Height="60"
                Padding="0">
                <PathIcon Data="{StaticResource chevron_left}"
                          Width="12" Height="12" />
            </ToggleButton>

            <!-- Label Map (Expandable 4th Image) -->
            <Border
                Grid.Column="6"
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsVisible="{Binding IsLabelMapExpanded}"
                Background="Transparent">
                <Image
                    Margin="0,4,0,0"
                    RenderOptions.BitmapInterpolationMode="None"
                    Source="{Binding LabelMapImage, Converter={StaticResource WriteableBitmapConverter}}"
                    Stretch="Uniform"/>
            </Border>

            <!-- Row 1: OK/Cancel bar -->
            <Border
                Grid.Row="1"
                Grid.ColumnSpan="7"
                Margin="-10,0,-10,-10"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"
                Background="{DynamicResource StatusBarBackground}"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,1,0,0"/>
            <elements:IconButton
                x:Name="BtnLoad1"
                Grid.Row="1"
                Grid.Column="0"
                Classes="outlined"
                Margin="10,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ap:MouseOverInfoAP.InfoText="Load Bricks Texture from the current selection"
                Icon="{StaticResource image_copy}"
                Command="{Binding LoadImage1Command}" />
            <elements:IconButton
                x:Name="BtnLoad2"
                Grid.Row="1"
                Grid.Column="2"
                Classes="outlined"
                Margin="10,5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ap:MouseOverInfoAP.InfoText="Load Background Texture from the current selection"
                Icon="{StaticResource image_copy}"
                Command="{Binding LoadImage2Command}" />
            <StackPanel
                Grid.Row="1"
                Grid.ColumnSpan="7"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <Button
                    Width="80"
                    Height="32"
                    Margin="0,0,15,0"
                    HorizontalAlignment="Right"
                    HorizontalContentAlignment="Center"
                    ap:MouseOverInfoAP.InfoText="Cancel and close the dialog"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding $parent[Window]}"
                    Content="Cancel"/>
                <Button
                    Classes="accent"
                    Width="80"
                    Height="32"
                    Margin="0,0,15,0"
                    HorizontalAlignment="Right"
                    HorizontalContentAlignment="Center"
                    ap:MouseOverInfoAP.InfoText="Apply the brick transition and close"
                    Command="{Binding OKCommand}"
                    CommandParameter="{Binding $parent[Window]}"
                    Content="OK"/>
            </StackPanel>
        </Grid>
    </Grid>
</elements:AsyncWindow>
