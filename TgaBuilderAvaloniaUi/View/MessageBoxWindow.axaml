<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:view="clr-namespace:TgaBuilderAvaloniaUi.View"
        mc:Ignorable="d" 
        d:DesignWidth="400" 
        d:DesignHeight="200"
        WindowStartupLocation="CenterScreen"
        SizeToContent="Height"
        x:DataType="view:MessageBoxWindow"
        x:Class="TgaBuilderAvaloniaUi.View.MessageBoxWindow"
        CanResize="False"
        CanMinimize="False"
        Width="400" 
        Height="200"
        Title="{Binding Header}"
        Icon="avares://TgaBuilderAvaloniaUi/Resources/TgaBuilder_icon.ico"
        >
  <Border Padding="16">
    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*">
      <!-- Header -->
      <TextBlock Text="{Binding Header}"
                 FontSize="18" FontWeight="Bold"
                 Margin="0,0,0,8"/>

      <!-- Message -->
      <TextBlock Grid.Row="1" Text="{Binding Message}"
                 TextWrapping="Wrap" />

      <!-- Buttons -->
      <StackPanel Grid.Row="2" Orientation="Horizontal"
                  HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">

        <Button x:Name="OkButton" 
                HorizontalContentAlignment="Center"
                Content="OK" 
                MinWidth="80"/>
        <Button x:Name="CancelButton" 
                HorizontalContentAlignment="Center"
                Content="Cancel" 
                MinWidth="80"/>
        <Button x:Name="YesButton" 
                HorizontalContentAlignment="Center"
                Content="Yes" 
                MinWidth="80"/>
        <Button x:Name="NoButton" 
                HorizontalContentAlignment="Center"
                Content="No" 
                MinWidth="80"/>
      </StackPanel>
    </Grid>
  </Border>
</Window>
