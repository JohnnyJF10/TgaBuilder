<elements:AsyncWindow 
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Class="TgaBuilderWpfUi.View.BrickTransitionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:TgaBuilderWpfUi.View" 
    xmlns:viewmodel="clr-namespace:TgaBuilderLib.ViewModel;assembly=TgaBuilderLib" 
    xmlns:sys="clr-namespace:System;assembly=mscorlib" 
    xmlns:wpfzoompanel="clr-namespace:WPFZoomPanel;assembly=WPF.ZoomPanel" 
    xmlns:elements="clr-namespace:TgaBuilderWpfUi.Elements"
    xmlns:ap="clr-namespace:TgaBuilderWpfUi.AttachedProperties"
    xmlns:converters="clr-namespace:TgaBuilderWpfUi.Converters"
    mc:Ignorable="d"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    Title="MainWindow"
    Width="800"
    Height="520"
    MinWidth="760"
    MinHeight="460"
    d:Background="Black"
    d:DataContext="{d:DesignInstance Type=viewmodel:BrickTransitionViewModel, IsDesignTimeCreatable=False}"
    >
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/ModifiedUiNumberBoxStyle.xaml"/>
                <ResourceDictionary Source="/Styles/TitleBarNavigationAreaStyle.xaml"/>
                <ResourceDictionary Source="/Styles/CheckerBrush.xaml"/>
                <ResourceDictionary Source="/Styles/MouseWheelSliderStyle.xaml"/>
                <ResourceDictionary Source="/Styles/TabControlStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:WriteableBitmapConverter x:Key="WriteableBitmapConverter"/>
            <sys:Boolean x:Key="True">True</sys:Boolean>
            <sys:Boolean x:Key="False">False</sys:Boolean>
            <Style TargetType="{x:Type elements:ContextMenuButton}"
                    BasedOn="{StaticResource {x:Type ui:Button}}"/>
        </ResourceDictionary>
    </Window.Resources>
    <!-- Outer Grid: 5 Rows -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title Bar -->
        <DockPanel Grid.Row="0">
            <ui:TitleBar
                DockPanel.Dock="Right"
                Width="133"
                Style="{StaticResource TitleBarNavigationAreaStyle}"/>
            <ui:TitleBar
                Title="Brick Transition Helper"
                ShowMinimize="False"
                ShowMaximize="False"
                ShowClose="False"
                Margin="3,3,0,0">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Resources/TgaBuilder_picture.png" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </DockPanel>

        <!-- Row 1: Settings / Options -->
        <Grid Grid.Row="1" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Col 0, Row 0: Transition Mode (always visible) -->
            <local:TransitionModeUserControl
                Grid.Column="0" Grid.Row="0"
                Margin="5,5,10,5"/>

            <!-- Col 0, Row 1: Always-visible sliders -->
            <StackPanel
                Grid.Column="0" Grid.Row="1"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="5,0,10,5">
                <Label VerticalAlignment="Center" Content="Pivot" TextBlock.FontStyle="Italic" Margin="0,0,3,0"/>
                <Slider
                    Width="100"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"
                    AutoToolTipPlacement="BottomRight"
                    AutoToolTipPrecision="2"
                    Maximum="1" Minimum="0" SmallChange="0.01"
                    Value="{Binding PivotValue}"/>
                <ui:ToggleSwitch
                    VerticalAlignment="Center"
                    IsChecked="{Binding ReversePivot}"
                    Padding="8,4"
                    TextBlock.FontStyle="Italic"
                    Content="Reverse"/>
            </StackPanel>

            <!-- Col 1, Row 0-1: Tab View -->
            <TabControl
                Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                Margin="0,5,5,5"
                BorderBrush="Transparent"
                TabStripPlacement="Top">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource NavTabItemStyle}">
                        <Setter Property="Height" Value="20"/>
                    </Style>
                </TabControl.Resources>

                <!-- Tab: Analysis -->
                <TabItem Header="Analysis" Height="25" Width="Auto">
                    <StackPanel Orientation="Horizontal" Margin="5,0" VerticalAlignment="Center">
                        <Label VerticalAlignment="Center" Content="Marker Radius" TextBlock.FontStyle="Italic" Margin="0,0,3,0"/>
                        <Slider
                            Width="100"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0"
                            AutoToolTipPlacement="BottomRight"
                            IsSnapToTickEnabled="True"
                            TickFrequency="1"
                            Maximum="10" Minimum="1" SmallChange="1"
                            Value="{Binding MarkerRadius}"/>
                        <Label VerticalAlignment="Center" Content="Segmentation" TextBlock.FontStyle="Italic" Margin="0,0,3,0"/>
                        <ComboBox
                            VerticalAlignment="Center"
                            MinWidth="130"
                            SelectedIndex="{Binding SelectedSegmentationMethodIndex, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Content="Watershed"/>
                            <ComboBoxItem Content="XY Projection"/>
                        </ComboBox>
                    </StackPanel>
                </TabItem>

                <!-- Tab: Options -->
                <TabItem Header="Options" Height="25" Width="Auto">
                    <StackPanel Orientation="Horizontal" Margin="5,0" VerticalAlignment="Center">
                        <Label VerticalAlignment="Center" Content="Filter" TextBlock.FontStyle="Italic" Margin="0,0,3,0"/>
                        <ComboBox
                            VerticalAlignment="Center"
                            MinWidth="130"
                            Margin="0,0,15,0"
                            SelectedIndex="{Binding SelectedFilterIndex, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Box Blur"/>
                            <ComboBoxItem Content="Median"/>
                            <ComboBoxItem Content="Bilateral"/>
                        </ComboBox>
                        <ui:ToggleSwitch
                            VerticalAlignment="Center"
                            IsChecked="{Binding SliceCornerTiles}"
                            Padding="8,4"
                            TextBlock.FontStyle="Italic"
                            Content="Slice Corners"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Row 2: From Selection / Mix buttons (aligned with image columns) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=LabelMapToggle}" Value="True">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BtnLoad1"
                Grid.Column="0"
                Margin="10,5"
                Padding="5"
                HorizontalAlignment="Center"
                Command="{Binding LoadImage1Command}"
                Content="From Selection"/>
            <Button
                x:Name="BtnLoad2"
                Grid.Column="2"
                Margin="10,5"
                Padding="5"
                HorizontalAlignment="Center"
                Command="{Binding LoadImage2Command}"
                Content="From Selection"/>
            <Button
                x:Name="BtnResult"
                Grid.Column="4"
                Margin="10,5"
                Padding="5"
                HorizontalAlignment="Center"
                Command="{Binding MixCommand}"
                Content="Mix"/>
        </Grid>

        <!-- Row 3: Image Area (Sub Table) -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=LabelMapToggle}" Value="True">
                                    <Setter Property="Width" Value="*"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- Image 1 -->
            <Border
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                AllowDrop="True"
                Background="Transparent">
                <Grid>
                    <Viewbox Stretch="Uniform" Margin="10"
                             RenderOptions.BitmapScalingMode="NearestNeighbor">
                        <Grid Width="{Binding Image1.PixelWidth, FallbackValue=128}"
                              Height="{Binding Image1.PixelHeight, FallbackValue=128}">
                            <Rectangle Fill="{StaticResource CheckerBrush}" />
                            <Image
                                x:Name="Image1"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                Source="{Binding Image1, Converter={StaticResource WriteableBitmapConverter}}"
                                Stretch="Fill"/>
                        </Grid>
                    </Viewbox>
                    <TextBlock
                        Text="Brick&#x0a;Texture"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        FontSize="18"
                        Visibility="{Binding InitTextVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                        IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Symbol: + -->
            <StackPanel
                VerticalAlignment="Center"
                Grid.Column="1">
                <ui:SymbolIcon Symbol="Add24"/>
                <ui:Button
                    Icon="{ui:SymbolIcon ArrowSwap24}" Margin="0,9,0,0"
                    Command="{Binding SwapImagesCommand}"/>
            </StackPanel>

            <!-- Image 2 -->
            <Border
                Grid.Column="2"
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                AllowDrop="True"
                Background="Transparent">
                <Grid>
                    <Viewbox Stretch="Uniform"
                             RenderOptions.BitmapScalingMode="NearestNeighbor">
                        <Grid Width="{Binding Image2.PixelWidth, FallbackValue=128}"
                              Height="{Binding Image2.PixelHeight, FallbackValue=128}">
                            <Rectangle Fill="{StaticResource CheckerBrush}" />
                            <Image
                                x:Name="Image2"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                Source="{Binding Image2, Converter={StaticResource WriteableBitmapConverter}}"
                                Stretch="Fill"/>
                        </Grid>
                    </Viewbox>
                    <TextBlock
                        Text="Background&#x0a;Texture"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        FontSize="18"
                        Visibility="{Binding InitTextVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                        IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Symbol: → -->
            <ui:SymbolIcon
                Grid.Column="3"
                Symbol="ArrowRight24"/>

            <!-- Result Image -->
            <Border
                Grid.Column="4"
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                AllowDrop="True"
                Background="Transparent">
                <Image
                    Margin="0,4,0,0"
                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                    Source="{Binding ResultImage, Converter={StaticResource WriteableBitmapConverter}}"
                    Stretch="Uniform"/>
            </Border>

            <!-- Toggle button for Label Map -->
            <ToggleButton
                x:Name="LabelMapToggle"
                Grid.Column="5"
                VerticalAlignment="Center"
                IsChecked="{Binding IsLabelMapExpanded}"
                Width="20"
                Height="60"
                Padding="0">
                <ToggleButton.Content>
                    <ui:SymbolIcon Symbol="ChevronLeft24"/>
                </ToggleButton.Content>
            </ToggleButton>

            <!-- Label Map (Expandable 4th Image) -->
            <Border
                Grid.Column="6"
                Margin="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Visibility="{Binding IsLabelMapExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="Transparent">
                <Image
                    Margin="0,4,0,0"
                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                    Source="{Binding LabelMapImage, Converter={StaticResource WriteableBitmapConverter}}"
                    Stretch="Uniform"/>
            </Border>
        </Grid>

        <!-- Row 4: OK/Cancel Buttons -->
        <Grid Grid.Row="4">
            <ui:Card
                Margin="-10,0,-10,-10"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False"/>
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal">
                <ui:Button
                    Width="75"
                    Height="30"
                    Margin="0,0,15,0"
                    HorizontalAlignment="Right"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="Cancel"/>
                <ui:Button
                    Width="75"
                    Height="30"
                    Margin="0,0,15,0"
                    HorizontalAlignment="Right"
                    Command="{Binding OKCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="OK"/>
            </StackPanel>
        </Grid>
    </Grid>
</elements:AsyncWindow>
