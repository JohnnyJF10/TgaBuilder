<elements:AsyncWindow
    x:Class="TgaBuilderWpfUi.View.SmoothTransitionWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ap="clr-namespace:TgaBuilderWpfUi.AttachedProperties"
    xmlns:converters="clr-namespace:TgaBuilderWpfUi.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:elements="clr-namespace:TgaBuilderWpfUi.Elements"
    xmlns:local="clr-namespace:TgaBuilderWpfUi.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewmodel="clr-namespace:TgaBuilderLib.ViewModel;assembly=TgaBuilderLib"
    xmlns:wpfzoompanel="clr-namespace:WPFZoomPanel;assembly=WPF.ZoomPanel"
    Title="MainWindow"
    Width="620"
    Height="460"
    MinWidth="580"
    MinHeight="410"
    d:Background="Black"
    d:DataContext="{d:DesignInstance Type=viewmodel:SmoothTransitionViewModel,
                                     IsDesignTimeCreatable=False}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/ModifiedUiNumberBoxStyle.xaml" />
                <ResourceDictionary Source="/Styles/TitleBarNavigationAreaStyle.xaml" />
                <ResourceDictionary Source="/Styles/CheckerBrush.xaml" />
                <ResourceDictionary Source="/Styles/MouseWheelSliderStyle.xaml" />
                <ResourceDictionary Source="/Styles/TabControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:WriteableBitmapConverter x:Key="WriteableBitmapConverter" />
            <sys:Boolean x:Key="True">True</sys:Boolean>
            <sys:Boolean x:Key="False">False</sys:Boolean>
            <Style BasedOn="{StaticResource {x:Type ui:Button}}" TargetType="{x:Type elements:ContextMenuButton}" />
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="35" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="35" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="5*" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <!-- Row 0: Title Bar -->
        <DockPanel Grid.ColumnSpan="5">
            <ui:TitleBar
                Width="133"
                DockPanel.Dock="Right"
                Style="{StaticResource TitleBarNavigationAreaStyle}" />
            <ui:TitleBar
                Title="Smooth Transition Helper"
                Grid.ColumnSpan="2"
                Margin="3,3,0,0"
                ShowClose="False"
                ShowMaximize="False"
                ShowMinimize="False">
                <ui:TitleBar.Icon>
                    <ui:ImageIcon Source="pack://application:,,,/Resources/TgaBuilder_picture.png" />
                </ui:TitleBar.Icon>
            </ui:TitleBar>
        </DockPanel>

        <!-- Row 1: Settings / Options -->
        <Grid Grid.Row="1" Grid.ColumnSpan="5" Margin="5,5,5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Col 0, Row 0: Transition Mode (always visible) -->
            <local:TransitionModeUserControl
                Grid.Column="0" Grid.Row="0"
                Margin="5,5,10,5" />

            <!-- Col 0, Row 1: Always-visible sliders -->
            <StackPanel
                Grid.Column="0" Grid.Row="1"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="5,0,10,5">
                <DockPanel Width="130" VerticalAlignment="Center" Margin="0,0,8,0"
                           ap:MouseOverInfoAP.InfoText="Pivot: sets the position of the transition border (0 = left, 1 = right)">
                    <Path DockPanel.Dock="Left" VerticalAlignment="Center"
                          Fill="{DynamicResource TextFillColorPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"
                          Data="{StaticResource arrow_left}" />
                    <Path DockPanel.Dock="Right" VerticalAlignment="Center"
                          Fill="{DynamicResource TextFillColorPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"
                          Data="{StaticResource arrow_right}" />
                    <Slider
                        Margin="5,0"
                        VerticalAlignment="Center"
                        AutoToolTipPlacement="BottomRight"
                        AutoToolTipPrecision="2"
                        Maximum="1" Minimum="0" SmallChange="0.01"
                        Value="{Binding PivotValue}" />
                </DockPanel>
                <DockPanel Width="130" VerticalAlignment="Center"
                           ap:MouseOverInfoAP.InfoText="Hardness: 0 = soft gradient blend, 1 = hard sharp edge">
                    <Path DockPanel.Dock="Left" VerticalAlignment="Center"
                          Fill="{DynamicResource TextFillColorPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"
                          Data="{StaticResource circle_half_fill}" />
                    <Path DockPanel.Dock="Right" VerticalAlignment="Center"
                          Fill="{DynamicResource TextFillColorPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"
                          Data="{StaticResource circle_line}" />
                    <Slider
                        Margin="5,0"
                        VerticalAlignment="Center"
                        AutoToolTipPlacement="BottomRight"
                        AutoToolTipPrecision="2"
                        Maximum="1" Minimum="0" SmallChange="0.01"
                        Value="{Binding BlendHardnessValue}" />
                </DockPanel>
            </StackPanel>

            <!-- Col 1, Row 0-1: Tab View -->
            <TabControl
                Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                Margin="0,5,5,5"
                BorderBrush="Transparent"
                TabStripPlacement="Top">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource NavTabItemStyle}">
                        <Setter Property="Height" Value="20" />
                    </Style>
                </TabControl.Resources>
                <TabItem Header="Blend" Height="25" Width="Auto">
                    <DockPanel Margin="5,0,5,0" VerticalAlignment="Center"
                               ap:MouseOverInfoAP.InfoText="Offset: shifts the blend position along the image (0 = no offset, 1 = full offset)">
                        <Path DockPanel.Dock="Left" VerticalAlignment="Center"
                              Fill="{DynamicResource TextFillColorPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"
                              Data="{StaticResource point_scan}" />
                        <Path DockPanel.Dock="Right" VerticalAlignment="Center"
                              Fill="{DynamicResource TextFillColorPrimaryBrush}" Width="14" Height="14" Stretch="Uniform"
                              Data="{StaticResource circle}" />
                        <Slider
                            Margin="5,0"
                            VerticalAlignment="Center"
                            AutoToolTipPlacement="BottomRight"
                            AutoToolTipPrecision="2"
                            Maximum="1" Minimum="0" SmallChange="0.01"
                            Value="{Binding OffsetValue}" />
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Row 2: From Selection / Mix buttons -->
        <Button
            x:Name="BtnLoad1"
            Grid.Row="2"
            Grid.Column="0"
            Margin="10,5"
            Padding="5"
            HorizontalAlignment="Center"
            ap:MouseOverInfoAP.InfoText="Load Texture 1 from the current selection"
            Command="{Binding LoadImage1Command}"
            CommandParameter="1"
            Content="From Selection" />
        <Button
            x:Name="BtnLoad2"
            Grid.Row="2"
            Grid.Column="2"
            Margin="10,5"
            Padding="5"
            HorizontalAlignment="Center"
            ap:MouseOverInfoAP.InfoText="Load Texture 2 from the current selection"
            Command="{Binding LoadImage2Command}"
            CommandParameter="2"
            Content="From Selection" />
        <Button
            x:Name="BtnResult"
            Grid.Row="2"
            Grid.Column="4"
            Margin="10,5"
            Padding="5"
            HorizontalAlignment="Center"
            ap:MouseOverInfoAP.InfoText="Generate the smooth transition result image"
            Command="{Binding MixCommand}"
            CommandParameter="2"
            Content="Mix" />

        <!-- Row 3: Images -->
        <!--  Image 1  -->
        <Border
            Grid.Row="3"
            Grid.Column="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AllowDrop="True"
            Background="Transparent">
            <Grid>
                <Viewbox Stretch="Uniform" Margin="10"
                         RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Grid Width="{Binding Image1.PixelWidth, FallbackValue=128}"
                          Height="{Binding Image1.PixelHeight, FallbackValue=128}">
                        <Rectangle Fill="{StaticResource CheckerBrush}" />
                        <Image
                            x:Name="Image1"
                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                            Source="{Binding Image1, Converter={StaticResource WriteableBitmapConverter}}"
                            Stretch="Fill" />
                    </Grid>
                </Viewbox>
                <TextBlock
                    Text="Texture 1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    FontSize="18"
                    Visibility="{Binding InitTextVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <StackPanel
            VerticalAlignment="Center"
            Grid.Column="1"
            Grid.Row="3">
            <ui:SymbolIcon Symbol="Add24"/>
            <ui:Button
                Icon="{ui:SymbolIcon ArrowSwap24}" Margin="0,9,0,0"
                ap:MouseOverInfoAP.InfoText="Swap Texture 1 and Texture 2"
                Command="{Binding SwapImagesCommand}" />
        </StackPanel>

        <!--  Image 2  -->
        <Border
            Grid.Row="3"
            Grid.Column="2"
            Margin="10"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AllowDrop="True"
            Background="Transparent">
            <Grid>
                <Viewbox Stretch="Uniform"
                         RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Grid Width="{Binding Image2.PixelWidth, FallbackValue=128}"
                          Height="{Binding Image2.PixelHeight, FallbackValue=128}">
                        <Rectangle Fill="{StaticResource CheckerBrush}" />
                        <Image
                            x:Name="Image2"
                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                            Source="{Binding Image2, Converter={StaticResource WriteableBitmapConverter}}"
                            Stretch="Fill" />
                    </Grid>
                </Viewbox>
                <TextBlock
                    Text="Texture 2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    FontSize="18"
                    Visibility="{Binding InitTextVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <ui:SymbolIcon
            Grid.Row="3"
            Grid.Column="3"
            Symbol="ArrowRight24" />

        <Border
            Grid.Row="3"
            Grid.Column="4"
            Margin="10"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AllowDrop="True"
            Background="Transparent">
            <Image
                Margin="0,4,0,0"
                RenderOptions.BitmapScalingMode="NearestNeighbor"
                Source="{Binding ResultImage, Converter={StaticResource WriteableBitmapConverter}}"
                Stretch="Uniform" />
        </Border>

        <!-- Row 4: OK/Cancel -->
        <ui:Card
            Grid.Row="4"
            Grid.ColumnSpan="5"
            Margin="-10,0,-10,-10"
            VerticalAlignment="Stretch"
            IsHitTestVisible="False" />
        <StackPanel
            Grid.Row="4"
            Grid.ColumnSpan="5"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Width="75"
                Height="30"
                Margin="0,0,15,0"
                HorizontalAlignment="Right"
                ap:MouseOverInfoAP.InfoText="Cancel and close the dialog"
                Command="{Binding CancelCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                Content="Cancel" />
            <ui:Button
                Width="75"
                Height="30"
                Margin="0,0,15,0"
                HorizontalAlignment="Right"
                ap:MouseOverInfoAP.InfoText="Apply the smooth transition and close"
                Command="{Binding OKCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                Content="OK" />
        </StackPanel>
    </Grid>
</elements:AsyncWindow>
